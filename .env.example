# Copy to .env (or apps/api/.env) — never commit real values.

# ---- Gemini AI (required) ----
# Get free key at https://aistudio.google.com/
# WARNING: free-tier prompts/responses are used by Google for training. See README.
GEMINI_API_KEY=test_key

# Single model — see apps/api/src/infra/ai/pricing.ts (only entry).
# Do not change without updating PROMPT_VERSION + rerunning Promptfoo evals.
GEMINI_PRIMARY_MODEL=gemini-3.1-flash-lite

# ---- AI cost / rate guardrails ----
GEMINI_DAILY_BUDGET_USD=0.50
GEMINI_MAX_INPUT_TOKENS=4000
# Explainer mode produces shorter outputs than the old picker mode, but
# kept at 4K — 3.1 Lite occasionally pads with caveats.
GEMINI_MAX_OUTPUT_TOKENS=4000
# Real free-tier limits observed for this project (2026-05).
GEMINI_RPM_LIMIT=15
GEMINI_RPD_LIMIT=500

# v1 = explainer-mode prompt. The deterministic window optimizer picks
# windows; the AI writes the narrative wrapper. Source of truth lives in
# apps/api/src/prompts/v1/ — Promptfoo evals read directly from there.
PROMPT_VERSION=v1

# ---- ENTSO-E (optional — synthetic fallback if missing) ----
ENTSOE_API_KEY=
ENTSOE_AREA_CODE=10Y1001A1001A92E

# ---- AWS (cloud) / local-docker overrides ----
AWS_REGION=eu-west-2
DYNAMODB_TABLE=EnergyInsightsTable
# Local docker only — Lambda uses the real DynamoDB SDK (no endpoint override).
DYNAMODB_ENDPOINT=http://host.docker.internal:8000
# Cloud only — SAM resolves the SSM SecureString at runtime.
# `sam local` reads GEMINI_API_KEY directly from .env instead.
GEMINI_KEY_PARAM=/uk-energy/dev/GEMINI_API_KEY

# ---- Logging ----
LOG_LEVEL=info
NODE_ENV=development
