    "@hono/node-server": "^1.13.7",
    "@uk-energy/shared": "*",
    "fast-xml-parser": "^4.5.1",
    "hono": "^4.6.16",
    "pino": "^9.5.0",
    "ulid": "^2.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.146",
    "tsx": "^4.19.2"
  }
