{
  "name": "@uk-energy/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lambda API for UK Energy & Carbon Insights — Hono + Gemini + DynamoDB",
  "main": "src/api.ts",
  "scripts": {
    "build": "tsc --noEmit",
